{
  "name": "v2camy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build-web": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "pack": "robocopy ./dist ./publish/amy/dist && robocopy ./app.js ./publish/amy/app.js && ./datatmp ./publish/amy/datatmp && ./start.bat ./publish/amy/start.bat",
    "build-node": "esbuild server.js --bundle --format=cjs --outfile=app.js --platform=node",
    "build": "npm run build-web && npm run build-node",
    "build-exe": "node --experimental-sea-config sea-config.json && npx postject gramy.exe NODE_SEA_BLOB sea-prep.blob --sentinel-fuse NODE_SEA_FUSE_fce680ab2cc467b6e072b8b5df1996b2",
    "build-srv": "npm run build-node && node -e \"require('fs').copyFileSync(process.execPath, 'gramy.exe')\"  && npm run build-exe"
  },
  "dependencies": {
    "@koa/multer": "^4.0.0",
    "@koa/router": "^13.1.0",
    "@serialport/parser-readline": "^12.0.0",
    "esbuild": "^0.24.2",
    "koa": "^2.15.3",
    "koa-bodyparser": "^4.4.1",
    "koa-static": "^5.0.0",
    "multer": "^2.1.1",
    "serialport": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@koa/cors": "^5.0.0",
    "@vue/cli-service": "^5.0.8",
    "axios": "^1.7.7",
    "element-ui": "^2.15.14",
    "vue": "^2.6.14"
  }
}
